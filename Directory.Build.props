<Project>
	<PropertyGroup>
		<Version>4.0.0-alpha1</Version>
		<AssemblyVersion>4.0.0</AssemblyVersion>
		<InformationalVersion>4.0.0-alpha1</InformationalVersion>
		<FileVersion>4.0.0-alpha1</FileVersion>
		<LangVersion Condition="'$(LangVersion)' == ''">10.0</LangVersion>
		<NeutralLanguage>en-US</NeutralLanguage>
		<TargetFramework>net8.0</TargetFramework>
		<Authors>Andy Butland</Authors>
		<Copyright>2021-23 Andy Butland</Copyright>
		<PackageProjectUrl>https://github.com/AndyButland/UmbracoPersonalisationGroupsCore/</PackageProjectUrl>
		<RepositoryUrl>https://github.com/AndyButland/UmbracoPersonalisationGroupsCore/</RepositoryUrl>
		<RepositoryType>Github</RepositoryType>
		<PackageTags>Umbraco</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
	</PropertyGroup>
</Project>

